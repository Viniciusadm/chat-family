rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /loginCodes/{code} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
