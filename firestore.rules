rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }
    function userTenant() {
      return get(userPath()).data.tenantId;
    }
    function memberId() {
      return get(userPath()).data.memberId;
    }
    function isTenantAdult() {
      return get(userPath()).data.role == 'adult';
    }
    function chatDoc(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId));
    }

    match /loginCodes/{code} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if request.auth != null;
    }

    match /tenants/{tenantId} {
      allow read: if request.auth != null && tenantId == userTenant();
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && tenantId == userTenant() && isTenantAdult();
    }

    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (resource.data.tenantId == userTenant() && isTenantAdult())
      );
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /members/{memberId} {
      allow read: if request.auth != null && resource.data.tenantId == userTenant();
      allow create: if request.auth != null && (
        (request.auth.uid == memberId && request.resource.data.tenantId is string) ||
        (
          isTenantAdult() &&
          request.resource.data.tenantId == userTenant() &&
          request.resource.data.keys().hasAll(['tenantId', 'name', 'role', 'loginCode', 'createdAt'])
        )
      );
      allow update, delete: if request.auth != null && resource.data.tenantId == userTenant() && isTenantAdult();
    }

    match /devices/{deviceId} {
      allow read: if request.auth != null && resource.data.tenantId == userTenant() && (
        resource.data.userId == request.auth.uid ||
        isTenantAdult()
      );
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.tenantId is string;
      allow update: if request.auth != null && resource.data.tenantId == userTenant() && (
        resource.data.userId == request.auth.uid ||
        isTenantAdult()
      );
      allow delete: if request.auth != null && resource.data.tenantId == userTenant() && isTenantAdult();
    }

    match /chats/{chatId} {
      allow read: if request.auth != null &&
        resource.data.tenantId == userTenant() &&
        memberId() in resource.data.participants;
      allow create: if request.auth != null &&
        request.resource.data.tenantId == userTenant() &&
        memberId() in request.resource.data.participants &&
        request.resource.data.keys().hasAll([
          'tenantId', 'participants', 'isGroup', 'name',
          'lastMessageText', 'lastMessageAt', 'lastMessageType', 'createdAt', 'updatedAt'
        ]);
      allow update, delete: if request.auth != null &&
        resource.data.tenantId == userTenant() &&
        memberId() in resource.data.participants;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if request.auth != null &&
        chatDoc(chatId).data.tenantId == userTenant() &&
        memberId() in chatDoc(chatId).data.participants;
      allow create: if request.auth != null &&
        memberId() in chatDoc(chatId).data.participants &&
        request.resource.data.senderId == memberId() &&
        request.resource.data.tenantId == chatDoc(chatId).data.tenantId &&
        request.resource.data.tenantId == userTenant() &&
        request.resource.data.keys().hasAll([
          'tenantId', 'senderId', 'text', 'audioUrl', 'audioDuration', 'createdAt'
        ]);
      allow update: if false;
      allow delete: if request.auth != null &&
        chatDoc(chatId).data.tenantId == userTenant() &&
        memberId() in chatDoc(chatId).data.participants;
    }
  }
}
